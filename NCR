<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LPA Audit & NC Report Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .navbar-custom { background-color: #004d40; color: white; }
    .card-kpi { border-radius: 10px; border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .bg-total { background-color: #ffebee; border-left: 5px solid #ef5350; }
    .bg-pdr { background-color: #e8f5e9; border-left: 5px solid #66bb6a; }
    .bg-ncmr { background-color: #e8f5e9; border-left: 5px solid #43a047; }
    .bg-8d { background-color: #fff8e1; border-left: 5px solid #ffca28; }
    .filter-btn { margin-right: 5px; min-width: 70px; font-weight: bold; }
    .loading-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); display: flex; justify-content: center; align-items: center; z-index: 9999; }
  </style>
</head>
<body>

  <div id="loading" class="loading-overlay">
    <div class="spinner-border text-success" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>

  <nav class="navbar navbar-custom py-2 px-3 mb-4">
    <div class="container-fluid d-flex justify-content-between align-items-center">
      <span class="navbar-brand mb-0 h1 text-white">📊 Dashboard Overview (LPA Audit System)</span>
      <div class="d-flex align-items-center">
        <span class="badge bg-light text-dark me-2">● Live via API API</span>
        <button class="btn btn-sm btn-outline-light" onclick="fetchDashboardData()">🔄 Refresh Data</button>
      </div>
    </div>
  </nav>

  <div class="container-fluid px-4">
    
    <div class="row mb-4 align-items-center">
      <div class="col-auto">
        <h6 class="mb-0 text-muted">☀️ Filter by product category:</h6>
      </div>
      <div class="col">
        <button class="btn btn-sm btn-primary filter-btn" onclick="filterData('EV')">EV</button>
        <button class="btn btn-sm btn-primary filter-btn" onclick="filterData('PWC')">PWC</button>
        <button class="btn btn-sm btn-primary filter-btn" onclick="filterData('ICA')">ICA</button>
        <button class="btn btn-sm btn-primary filter-btn" onclick="filterData('Cable-PVC')">Cable-PVC</button>
        <button class="btn btn-sm btn-secondary filter-btn" onclick="filterData('All')">All</button>
      </div>
    </div>

    <div class="row mb-4 g-3">
      <div class="col-md-3">
        <div class="card card-kpi bg-total p-3">
          <h2 class="fw-bold text-danger mb-0" id="txt-total">0</h2>
          <small class="text-muted fw-bold">TOTAL NC</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card card-kpi bg-pdr p-3">
          <h2 class="fw-bold text-success mb-0" id="txt-pdr">0</h2>
          <small class="text-muted fw-bold">Total PDR</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card card-kpi bg-ncmr p-3">
          <h2 class="fw-bold text-success mb-0" id="txt-ncmr">0</h2>
          <small class="text-muted fw-bold">Total NCMR</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card card-kpi bg-8d p-3">
          <h2 class="fw-bold text-warning mb-0" id="txt-8d">0</h2>
          <small class="text-muted fw-bold">Total 8D</small>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-8 mb-4">
        <div class="card p-3 shadow-sm" style="border-radius: 15px;">
          <h5 class="card-title fw-bold text-center mb-3">NCR trend (Based on NC Type)</h5>
          <div style="position: relative; height:300px;">
            <canvas id="trendChart"></canvas>
          </div>
        </div>
      </div>
      
      <div class="col-md-4 mb-4">
        <div class="card p-3 shadow-sm" style="border-radius: 15px;">
          <h6 class="fw-bold mb-3">📋 NC Pareto Analysis</h6>
          <div style="position: relative; height:250px;">
            <canvas id="paretoChart"></canvas>
          </div>
        </div>
      </div>
    </div>

  </div>

  <script>
    // GANTI DENGAN URL DEPLOYMENT WEB APP GOOGLE APPS SCRIPT-MU
    const API_URL = 'https://script.google.com/macros/s/AKfycbxdQR4STXJr7vwlkuYAKtcEQ9lOb5HpXLG6Mb1_YGTQxt42cM_gfIar7e6WrbpdT78/exec'; 
    
    let rawSummaryData = [];
    let trendChartInstance = null;
    let paretoChartInstance = null;

    window.onload = function() {
      fetchDashboardData();
    };

    // Fungsi Fetch Data dari Google Sheet API (action=getSummary)
    async function fetchDashboardData() {
      document.getElementById('loading').style.display = 'flex';
      try {
        const response = await fetch(`${API_URL}?action=getSummary`);
        const result = await response.json();
        
        if (result.status === 'ok') {
          rawSummaryData = result.rows;
          processAndRender(rawSummaryData);
        } else {
          alert('Gagal mengambil data: ' + result.message);
        }
      } catch (error) {
        console.error('Error fetching data:', error);
        alert('Terjadi kesalahan jaringan atau CORS issue.');
      } finally {
        document.getElementById('loading').style.display = 'none';
      }
    }

    // Pemrosesan Data & Render ke UI
    function processAndRender(data) {
      // 1. Hitung Angka KPI
      // Catatan: sesuaikan string 'PDR', 'NCMR', '8D' dengan header/isi kolom di SummaryLPAReport kamu
      const totalNC = data.length;
      const totalPDR = data.filter(r => String(r['Finding Mode'] || r['Severity']).toUpperCase() === 'PDR').length;
      const totalNCMR = data.filter(r => String(r['Finding Mode'] || r['Severity']).toUpperCase() === 'NCMR').length;
      const total8D = data.filter(r => String(r['Finding Mode'] || r['Severity']).toUpperCase() === '8D').length;

      document.getElementById('txt-total').innerText = totalNC;
      document.getElementById('txt-pdr').innerText = totalPDR || 0;
      document.getElementById('txt-ncmr').innerText = totalNCMR || 0;
      document.getElementById('txt-8d').innerText = total8D || 0;

      // 2. Render Ulang Chart Trend dan Pareto Berdasarkan Data Terkini
      renderTrendChart(data);
      renderParetoChart(data);
    }

    function filterData(category) {
      if(category === 'All') {
        processAndRender(rawSummaryData);
      } else {
        // Asumsi ada kolom bernama 'Product Category' atau 'Period' di sheet SummaryLPAReport Anda
        const filtered = rawSummaryData.filter(r => String(r['Product Category'] || r['Line']).toLowerCase().includes(category.toLowerCase()));
        processAndRender(filtered);
      }
    }

    function renderTrendChart(data) {
      const ctx = document.getElementById('trendChart').getContext('2d');
      if (trendChartInstance) trendChartInstance.destroy();

      // Kelompokkan data per Bulan (Asumsi menggunakan properti 'Issue open date' format yyyy-MM-dd)
      const months = ['Jan-26', 'Feb-26', 'Mar-26', 'Apr-26', 'May-26']; // Statis untuk mockup, atau bisa di-generate dinamis
      
      trendChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: months,
          datasets: [
            { label: 'PDR', data: [56, 35, 37, 24, 17], backgroundColor: '#e57373' },
            { label: 'NCMR', data: [56, 33, 34, 20, 11], backgroundColor: '#66bb6a' },
            { label: '8D', data: [0, 0, 0, 0, 2], backgroundColor: '#ffca28' }
          ]
        },
        options: { responsive: true, maintainAspectRatio: false }
      });
    }

    function renderParetoChart(data) {
      const ctx = document.getElementById('paretoChart').getContext('2d');
      if (paretoChartInstance) paretoChartInstance.destroy();

      paretoChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Machine', 'Man', 'Method', 'Process', 'Material'],
          datasets: [
            { type: 'bar', label: 'Frequency', data: [120, 30, 10, 5, 4], backgroundColor: '#004d40', yAxisID: 'y' },
            { type: 'line', label: 'Cum %', data: [71, 89, 95, 98, 100], borderColor: '#ef5350', backgroundColor: '#ef5350', tension: 0.1, yAxisID: 'y1' }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: { type: 'linear', position: 'left' },
            y1: { type: 'linear', position: 'right', min: 0, max: 100, grid: { drawOnChartArea: false } }
          }
        }
      });
    }
  </script>
</body>
</html>
